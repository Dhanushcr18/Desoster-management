VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

# Optional: OpenWeather API key for real-time weather data (https://openweathermap.org/api)
# Get a free API key from: https://home.openweathermap.org/users/sign_up
# VITE_OPENWEATHER_API_KEY=your-openweather-api-key-here

# Optional: Switch to Mapbox (requires API key from https://www.mapbox.com/)
# VITE_MAPBOX_TOKEN=pk.your-mapbox-token-here
